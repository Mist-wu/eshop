# 易付通支付配置
# 设为 true 后，前台会自动显示支付宝和微信支付
EM_YIFUT_ENABLE=false

# 可选：内部更新服务令牌
EM_SERVICE_TOKEN=

# 商户号（pid）
EM_YIFUT_PID=

# 商户私钥
# 支持两种写法：
# 1. 直接粘贴完整 PEM（推荐用双引号包裹，可跨行）
# 2. 只粘贴去掉 BEGIN/END 的纯内容，保持单行
EM_YIFUT_PRIVATE_KEY=

# 易付通平台公钥
# 同样支持完整 PEM 或去掉 BEGIN/END 的单行内容
EM_YIFUT_PUBLIC_KEY=

# 可选：指定进件通道 ID，不需要留空
EM_YIFUT_CHANNEL_ID=

# 可选：分别控制支付宝 / 微信支付入口
EM_YIFUT_ENABLE_ALIPAY=true
EM_YIFUT_ENABLE_WXPAY=true

# 可选：自定义易付通 API 基础地址
EM_YIFUT_API_BASE=https://www.yifut.com/api

# 可选：统一下单模式，默认 jump
EM_YIFUT_CREATE_METHOD=jump

# 可选：订单过期秒数，默认 1800 秒
EM_ORDER_EXPIRE_SECONDS=1800
